# DuaBiskutTelur — backend API keys (never commit real keys)
# Copy to .env or set these as environment variables before starting the backend.

# Google Gemini API key (free tier available)
# Get one at: https://aistudio.google.com  ->  "Get API key"
# Without it, the backend serves a realistic mocked analysis (nasi lemak sample)
# so the frontend can be developed and demoed offline.
GEMINI_API_KEY=

# Optional backup Gemini keys. When the primary key hits the free-tier rate
# limit (HTTP 429), the backend automatically falls back to GEMINI_API_KEY_2,
# then GEMINI_API_KEY_3. Once a key's cooldown passes, it's preferred again
# ahead of any backup — GEMINI_API_KEY is always tried first. Safe to leave
# blank if you only have one key.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# USDA FoodData Central API key (free)
# Sign up at: https://fdc.nal.usda.gov/api-key-signup
# Without it, nutrition falls back to the vision model's estimates
# (foods are flagged "source": "estimated").
USDA_API_KEY=

# Google OAuth 2.0 credentials for "Sign in with Google".
# Create at: https://console.cloud.google.com  ->  APIs & Services -> Credentials
#   Application type: Web application
#   Authorized redirect URIs (add both):
#     https://<your-domain>/login/oauth2/code/google      # production
#     http://localhost:8080/login/oauth2/code/google      # local testing
# Required for login; without it the backend starts but /oauth2/authorization/google fails.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Extra origins allowed to make credentialed cross-origin API calls,
# comma-separated. Not needed for the standard setup: the Vite dev server is
# allowed by default, and in production the frontend is served same-origin.
# CORS_ALLOWED_ORIGINS=
