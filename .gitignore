# ============================================================
# Secrets — never commit real keys, credentials, or identities
# ============================================================
.env
.env.local
.env.production
.env.*.local
secrets/
*.key
*.pem
*.p12
*.jks
*.keystore
keystore-password.txt
# Private operational notes (VM addresses, signing credentials, SSH details)
HANDOVER.private.md

# Backend
backend/target/
backend/data/
backend/application-local.yml
backend/application-prod.yml

# Frontend
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/.vite/

# ============================================================
# Android — the TWA project under android/ is fully generated by
# generate.js (Bubblewrap), and the directory also holds the signing
# keystore and signed release artifacts. Only generate.js is authored
# source; nothing else in there belongs in a public repository.
# ============================================================
android/*
!android/generate.js

# Local tooling & IDE config (machine-specific paths live here)
.claude/
.idea/
.vscode/
*.iml

# Historical project-prompt document (kept locally, not part of the release)
DuaBiskutTelur.md

# Build output (generic)
build/
target/
coverage/

# OS / editor / logs
.DS_Store
Thumbs.db
*.log
logs/
*.swp
